@prefix : <http://knuckles.team/kg#> .
@prefix shape: <http://knuckles.team/kg/repository/shape#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

shape:GitRepositoryGovernanceShape a sh:NodeShape ;
    sh:targetClass :GitRepository ;
    sh:closed false ;
    sh:property [
        sh:path :sourceRecordRef ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :tenantReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :accessPolicyReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :provenanceReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] .

shape:ProjectGovernanceShape a sh:NodeShape ;
    sh:targetClass :Project ;
    sh:closed false ;
    sh:property [
        sh:path :sourceRecordRef ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :tenantReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :accessPolicyReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :provenanceReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] .

shape:WorktreeGovernanceShape a sh:NodeShape ;
    sh:targetClass :Worktree ;
    sh:closed false ;
    sh:property [
        sh:path :sourceRecordRef ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :tenantReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :accessPolicyReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :provenanceReference ;
        sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string
    ] .
