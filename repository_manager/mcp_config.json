{
  "mcpServers": {
    "repository-manager": {
      "command": "repository-manager-mcp",
      "args": [
        "--transport",
        "stdio"
      ],
      "env": {
        "FILE_OPERATIONSTOOL": "${ FILE_OPERATIONSTOOL:-True }",
        "MISCTOOL": "${ MISCTOOL:-True }",
        "GIT_OPERATIONSTOOL": "${ GIT_OPERATIONSTOOL:-True }",
        "GRAPH_INTELLIGENCETOOL": "${ GRAPH_INTELLIGENCETOOL:-True }",
        "REPOSITORY_MANAGER_THREADS": "secret://REPOSITORY_MANAGER_THREADS",
        "REPOSITORY_MANAGER_WORKSPACE": "secret://REPOSITORY_MANAGER_WORKSPACE",
        "VISUALIZATIONTOOL": "${ VISUALIZATIONTOOL:-True }",
        "WORKSPACE_MANAGEMENTTOOL": "${ WORKSPACE_MANAGEMENTTOOL:-True }",
        "WORKSPACE_YML": "secret://WORKSPACE_YML"
      }
    }
  }
}
